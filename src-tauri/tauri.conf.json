{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "91",
  "version": "2.0.1",
  "identifier": "local.gpt.cost.calculator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "91",
        "width": 1360,
        "height": 880,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
